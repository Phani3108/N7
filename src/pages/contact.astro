---
import Base from '../layouts/Base.astro';
---
<Base title="Contact — Number7" description="One inbox. Answered in a day. Write to hello@number7.io or book a 30-minute working session.">
  <section class="subhero"><div class="container">
    <div class="crumbs">Home / Contact</div>
    <h1 class="serif">One inbox. Answered in a day.</h1>
    <p class="lede">We like email. It's asynchronous, archivable, and forces us to write clearly. Tell us what you're building — we'll reply with specifics.</p>
  </div></section>

  <section class="contact"><div class="container">
    <div class="wrap">
      <div>
        <div class="field"><b>General</b><a href="mailto:hello@number7.io">hello@number7.io</a></div>
        <div class="field"><b>Phone</b><a href="tel:+919392963113">+91 93929 63113</a></div>
        <div class="field"><b>Sales &amp; pilots</b><a href="mailto:sales@number7.io">sales@number7.io</a></div>
        <div class="field"><b>Security &amp; disclosure</b><a href="mailto:security@number7.io">security@number7.io</a></div>
        <div class="field"><b>Privacy &amp; DSARs</b><a href="mailto:privacy@number7.io">privacy@number7.io</a></div>
        <div class="field"><b>Press</b><a href="mailto:press@number7.io">press@number7.io</a></div>
        <div class="field"><b>Careers</b><a href="mailto:careers@number7.io">careers@number7.io</a></div>
        <div class="field"><b>Offices</b><span>India · UAE · Qatar · Singapore · Zimbabwe · USA · UK</span></div>
      </div>
      <div class="box">
        <h3 class="serif" style="margin:0 0 8px">Rather meet?</h3>
        <p style="color:var(--muted); margin:0 0 20px; font-size:14px">Book a 30-minute working session. Bring a real problem. Leave with a prototype.</p>
        <a class="btn ember" href="mailto:hello@number7.io?subject=Working%20session" style="width:100%; justify-content:center">Book a working session <span class="arrow">→</span></a>
        <p style="color:var(--muted); font-size:13px; margin-top:14px">We read every message. If we can't help, we'll say so and point you at someone who can.</p>
      </div>
    </div>
  </div></section>
</Base>
