---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('products');
const products = all
  .filter(p => p.data.bucket === 'B2B')
  .sort((a, b) => a.data.order - b.data.order);
---
<Base title="B2B — Work that agents can own · Number7" description="Five flagships plus supporting products. Enterprise AgentOS, Cortex, Zeta IMA, Digitalization of Schools, Digital Twin.">
  <section class="subhero"><div class="container">
    <div class="crumbs">Home / Products / B2B</div>
    <h1 class="serif">Work that agents can own.</h1>
    <p class="lede">Tools that don't just help — they hold the pager. Five flagships built to sit on the org chart, not in the integrations tab.</p>
  </div></section>

  <section><div class="container">
    <div class="product-grid">
      {products.map(p => (
        <ProductCard
          slug={p.slug}
          title={p.data.title}
          bucket={`${p.data.bucket} · ${p.data.category}`}
          blurb={p.data.blurb}
          tagline={p.data.tagline}
          dark={p.data.dark}
        />
      ))}
    </div>
  </div></section>
</Base>
