---
import Base from '../layouts/Base.astro';
import Pipeline from '../components/Pipeline.astro';
---
<Base>
  <section class="hero"><div class="container">
    <span class="eyebrow">AI agents · Number 7 Cognition LLP</span>
    <h1 class="serif">Six days, the world <em>talks</em> about AI.<br/>On the seventh, we ship it.</h1>
    <p class="sub">Number7 builds agents that earn their desk — in boardrooms, factory floors, and phone calls. Lean team. Weekly releases. Receipts, not roadmaps.</p>
    <div class="cta-row">
      <a class="btn ember" href="/products">See what shipped this week <span class="arrow">→</span></a>
      <a class="btn ghost" href="/contact">Book a working session</a>
    </div>
  </div></section>

  <section class="strip"><div class="container">
    <div class="grid">
      <div>
        <div class="n">01 / Cadence</div>
        <h3 class="serif">We ship weekly.</h3>
        <p>Every Friday, something real goes live. Roadmaps are fiction written after the fact.</p>
      </div>
      <div>
        <div class="n">02 / Evidence</div>
        <h3 class="serif">We measure in outcomes.</h3>
        <p>Hours reclaimed. Tickets closed. Calls screened. If a number doesn't move, the feature didn't ship.</p>
      </div>
      <div>
        <div class="n">03 / Humility</div>
        <h3 class="serif">We stay out of the way.</h3>
        <p>Agents work inside the tools your team already opens. No new tabs, no new logins, no rituals.</p>
      </div>
    </div>
  </div></section>

  <section class="services-teaser"><div class="container">
    <div class="sec-label">
      <h2 class="serif">From idea to launch to scale.<br/>One team.</h2>
      <div class="meta">Services · Seven phases</div>
    </div>
    <p class="teaser-lede">We partner with enterprises end-to-end — ground survey to go-live to operations. Pick up at any phase. Every phase has receipts.</p>
    <Pipeline compact={false} />
    <div style="margin-top:28px; display:flex; gap:10px; flex-wrap:wrap">
      <a class="btn ember" href="/idea-to-launch">See the engagement <span class="arrow">→</span></a>
      <a class="btn ghost" href="mailto:hello@number7.io?subject=Quote%20%E2%80%94%20Full%20engagement">Request a quote</a>
    </div>
  </div></section>

  <section class="groups"><div class="container">
    <div class="sec-label">
      <h2 class="serif">What we build.</h2>
      <div class="meta">Ten flagships · Two surfaces</div>
    </div>
    <div class="group-grid">
      <div class="group">
        <div>
          <div class="tag">B2B · Flagship</div>
          <h3 class="serif">Work that agents can own.</h3>
          <p class="sub">Tools that don't just help — they hold the pager.</p>
          <ul>
            <li><a href="/products/enterprise-agent-os"><span>Enterprise AgentOS</span><span>→</span></a></li>
            <li><a href="/products/cortex"><span>Cortex</span><span>→</span></a></li>
            <li><a href="/products/zeta-ima"><span>Zeta IMA</span><span>→</span></a></li>
            <li><a href="/products/digitalization-of-schools"><span>Digitalization of Schools</span><span>→</span></a></li>
            <li><a href="/products/digital-twin"><span>Digital Twin</span><span>→</span></a></li>
          </ul>
        </div>
        <a class="more" href="/products/b2b">Explore the B2B stack →</a>
      </div>

      <div class="group b2c">
        <div>
          <div class="tag">B2C · Flagship</div>
          <h3 class="serif">AI that lives in your life.</h3>
          <p class="sub">We built the assistant your phone always promised.</p>
          <ul>
            <li><a href="/products/vexa"><span>Vexa</span><span>→</span></a></li>
            <li><a href="/products/transactionwonder"><span>TransactionWonder</span><span>→</span></a></li>
            <li><a href="/products/shadow"><span>Shadow</span><span>→</span></a></li>
            <li><a href="/products/cadbury"><span>Cadbury</span><span>→</span></a></li>
            <li><a href="/products/questnet"><span>QuestNet</span><span>→</span></a></li>
          </ul>
        </div>
        <a class="more" href="/products/b2c">Explore the consumer suite →</a>
      </div>
    </div>
  </div></section>

  <section class="spotlight"><div class="container">
    <div class="wrap">
      <div>
        <div class="eyebrow">This week's agent at work</div>
        <h2 class="serif">Enterprise AgentOS runs 53 autonomous agents across five regiments — while your team runs the meeting.</h2>
        <p style="color:var(--muted); max-width:520px">Six persona workspaces. Sixty skills. One-fifty API routes. The operating system for teams that want agents on the org chart.</p>
        <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap">
          <a class="btn ghost" href="/products/enterprise-agent-os">See the workflow canvas <span class="arrow">→</span></a>
          <a class="btn ghost" href="https://enterprise-agent-os-web.vercel.app/home" target="_blank" rel="noopener">Open the live app <span class="arrow">↗</span></a>
        </div>
      </div>
      <figure class="spotlight-shot">
        <a href="https://enterprise-agent-os-web.vercel.app/" target="_blank" rel="noopener" aria-label="Enterprise AgentOS — open the live site in a new tab">
          <img
            src="/screenshots/enterprise-agent-os.png"
            alt="Enterprise AgentOS landing page — The AI Operating System for Enterprise Teams"
            width="1440"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </a>
        <figcaption>
          <span><b>53</b> agents · 5 regiments</span>
          <span><b>150+</b> API routes</span>
        </figcaption>
      </figure>
    </div>
  </div></section>

  <section id="manifesto" class="manifesto"><div class="container">
    <blockquote class="serif">
      The <em>seventh day</em> was never about rest. It was about finishing the work. Number7 ships on the day everyone else talks. We think AI belongs on the org chart, not the keynote slide. And we're building toward a plain, unromantic goal — <em>that the next billion people meet AI the way they meet electricity</em>. Everyday. Unremarkable. Already on.
    </blockquote>
    <div class="author">— The House, Number 7 Cognition LLP</div>
  </div></section>

  <section class="trust"><div class="container">
    <div class="sec-label">
      <h2 class="serif">Built to be trusted.</h2>
      <div class="meta">Security · Privacy · Evidence</div>
    </div>
    <div class="grid">
      <div class="item"><h4>SOC 2 Type II</h4><p>Controls audited annually. Report on request under NDA.</p></div>
      <div class="item"><h4>Data residency</h4><p>US, EU, and IN regions. Customer data never leaves the chosen region.</p></div>
      <div class="item"><h4>Model governance</h4><p>Prompt, model, and tool-use logs kept per-tenant for 13 months.</p></div>
      <div class="item"><h4>Vulnerability disclosure</h4><p>Public program, 24h triage SLA, safe-harbor for researchers.</p></div>
    </div>
    <div style="margin-top:28px"><a class="btn ghost" href="/trust">Read our trust posture <span class="arrow">→</span></a></div>
  </div></section>

  <section class="careers"><div class="container">
    <div class="wrap">
      <h2 class="serif">Small team.<br/>Large surface area.<br/>Write to us.</h2>
      <div>
        <p>We don't post job descriptions. We post problems. If one of them is yours, tell us how you'd solve it and we'll reply in 48 hours.</p>
        <a class="btn ember" href="mailto:hello@number7.io">hello@number7.io <span class="arrow">→</span></a>
      </div>
    </div>
  </div></section>
</Base>
