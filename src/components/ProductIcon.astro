---
interface Props {
  slug: string;
  size?: number;
  title?: string;
}
const { slug, size = 24, title } = Astro.props;
const ariaHidden = title === undefined;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={ariaHidden ? undefined : 'img'}
  aria-hidden={ariaHidden ? 'true' : undefined}
  aria-label={title}
  class="product-icon"
>
  {slug === 'enterprise-agent-os' && (
    <>
      <circle cx="6" cy="6" r="1.4" fill="none"/>
      <circle cx="12" cy="6" r="1.4" fill="none"/>
      <circle cx="18" cy="6" r="1.4" fill="none"/>
      <circle cx="6" cy="12" r="1.4" fill="none"/>
      <circle cx="12" cy="12" r="2" fill="#E85D3C" stroke="none"/>
      <circle cx="18" cy="12" r="1.4" fill="none"/>
      <circle cx="6" cy="18" r="1.4" fill="none"/>
      <circle cx="12" cy="18" r="1.4" fill="none"/>
      <circle cx="18" cy="18" r="1.4" fill="none"/>
    </>
  )}

  {slug === 'cortex' && (
    <>
      <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/>
      <line x1="12" y1="12" x2="22" y2="12"/>
      <line x1="12" y1="12" x2="2" y2="12"/>
      <line x1="12" y1="12" x2="17" y2="3.3"/>
      <line x1="12" y1="12" x2="7" y2="3.3"/>
      <line x1="12" y1="12" x2="17" y2="20.7"/>
      <line x1="12" y1="12" x2="7" y2="20.7"/>
    </>
  )}

  {slug === 'zeta-ima' && (
    <>
      <polyline points="5 6 19 6 5 18 19 18"/>
      <path d="M20 3 L20 7 M18 5 L22 5"/>
    </>
  )}

  {slug === 'digitalization-of-schools' && (
    <>
      <path d="M3 10 L12 7 L12 19 L3 16 Z"/>
      <path d="M21 10 L12 7 L12 19 L21 16 Z"/>
      <path d="M7 5 Q12 1 17 5"/>
    </>
  )}

  {slug === 'digital-twin' && (
    <>
      <circle cx="9" cy="12" r="6"/>
      <circle cx="15" cy="12" r="6"/>
    </>
  )}

  {slug === 'vexa' && (
    <>
      <path d="M12 3 L20 6 L20 13 Q20 18 12 22 Q4 18 4 13 L4 6 Z"/>
      <path d="M8.5 9.5 L10 11 Q11 12 10 13 L9 14 Q11 16 13 17 L14 16 Q15 15 16 16 L17.5 17.5"/>
    </>
  )}

  {slug === 'transactionwonder' && (
    <>
      <line x1="3" y1="7" x2="14" y2="7"/>
      <line x1="3" y1="11" x2="14" y2="11"/>
      <line x1="3" y1="15" x2="11" y2="15"/>
      <polyline points="15 15 18 18 22 12" stroke="#E85D3C"/>
    </>
  )}

  {slug === 'shadow' && (
    <>
      <circle cx="12" cy="12" r="9"/>
      <path d="M12 3 A9 9 0 0 1 12 21 A6 9 0 0 0 12 3 Z" fill="currentColor" stroke="none"/>
    </>
  )}

  {slug === 'cadbury' && (
    <>
      <circle cx="12" cy="3.5" r="1.4" fill="currentColor" stroke="none"/>
      <circle cx="19.4" cy="8" r="1.4" fill="currentColor" stroke="none"/>
      <circle cx="18" cy="16.5" r="1.4" fill="currentColor" stroke="none"/>
      <circle cx="12" cy="20.5" r="1.4" fill="currentColor" stroke="none"/>
      <circle cx="6" cy="16.5" r="1.4" fill="currentColor" stroke="none"/>
      <circle cx="4.6" cy="8" r="1.4" fill="currentColor" stroke="none"/>
      <circle cx="12" cy="12" r="2" fill="#E85D3C" stroke="none"/>
    </>
  )}

  {slug === 'questnet' && (
    <>
      <rect x="3" y="3" width="10" height="10" rx="2"/>
      <polyline points="6 8 8 10 11 6"/>
      <line x1="14" y1="18" x2="21" y2="18"/>
      <polyline points="18 15 21 18 18 21"/>
    </>
  )}

  {slug === 'dealframe' && (
    <>
      <polyline points="5 5 2 5 2 19 5 19"/>
      <polyline points="19 5 22 5 22 19 19 19"/>
      <path d="M8 10 Q8 9 9 9 L10 9 Q11 9 11 10 Q11 11 10 11 L9 13 M14 10 Q14 9 15 9 L16 9 Q17 9 17 10 Q17 11 16 11 L15 13"/>
    </>
  )}

  {slug === 'musicluv' && (
    <>
      <ellipse cx="7.5" cy="17.5" rx="3" ry="2.3" transform="rotate(-18 7.5 17.5)"/>
      <line x1="10" y1="16.5" x2="10" y2="5"/>
      <path d="M10 5 Q17 6 17 11"/>
      <circle cx="18" cy="18" r="1.4" fill="#E85D3C" stroke="none"/>
    </>
  )}

  {slug === 'three-d-world' && (
    <>
      <circle cx="12" cy="12" r="9"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <ellipse cx="12" cy="12" rx="4" ry="9"/>
    </>
  )}

  {slug === 'propertycalculator' && (
    <>
      <polyline points="3 12 12 4 21 12"/>
      <polyline points="5 11 5 20 19 20 19 11"/>
      <rect x="10" y="14" width="4" height="6"/>
      <line x1="15.5" y1="14" x2="17.5" y2="14"/>
      <line x1="15.5" y1="16" x2="17.5" y2="16"/>
    </>
  )}
</svg>
