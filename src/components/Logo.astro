---
interface Props {
  size?: number;
  mono?: boolean;
}
const { size = 34, mono = false } = Astro.props;
const width = Math.round(size * 2.6);
const dotColor = mono ? '#C9F24A' : '#E85D3C';
---
<a class="logo" href="/" aria-label="Number7 home">
  <svg width={width} height={size} viewBox="0 0 104 40" role="img" aria-hidden="true">
    <!-- Geometric AI mark: three agents on a shared orbit -->
    <circle cx="16" cy="20" r="10" stroke="currentColor" stroke-width="1.8" fill="none"/>
    <circle cx="16" cy="10" r="2.6" fill={dotColor}/>
    <circle cx="24.66" cy="25" r="2.4" fill="currentColor"/>
    <circle cx="7.34" cy="25" r="2.4" fill="currentColor"/>
    <!-- Subtle divider -->
    <line x1="34" y1="10" x2="34" y2="30" stroke="currentColor" stroke-width="1" opacity="0.18"/>
    <!-- N7 wordmark -->
    <text
      x="42" y="32"
      font-family="ui-serif, 'Iowan Old Style', 'Instrument Serif', Georgia, serif"
      font-size="34"
      font-weight="600"
      fill="currentColor"
      letter-spacing="-2"
    >N7</text>
    <circle cx="98" cy="30" r="3" fill={dotColor}/>
  </svg>
</a>
