---
interface Props {
  phase: 'discover' | 'define' | 'design' | 'build' | 'ship' | 'launch' | 'scale';
  size?: number;
}
const { phase, size = 24 } = Astro.props;
---
<svg
  width={size} height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class="phase-icon"
>
  {phase === 'discover' && (
    <>
      <circle cx="10" cy="10" r="6"/>
      <line x1="14.5" y1="14.5" x2="20" y2="20"/>
      <circle cx="10" cy="10" r="1.5" fill="currentColor" stroke="none"/>
    </>
  )}
  {phase === 'define' && (
    <>
      <path d="M5 5 L3 5 L3 19 L5 19"/>
      <path d="M19 5 L21 5 L21 19 L19 19"/>
      <line x1="8" y1="12" x2="16" y2="12"/>
      <circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none"/>
    </>
  )}
  {phase === 'design' && (
    <>
      <path d="M5 19 L5 15 L16 4 L20 8 L9 19 Z"/>
      <line x1="14" y1="6" x2="18" y2="10"/>
      <line x1="5" y1="19" x2="9" y2="19"/>
    </>
  )}
  {phase === 'build' && (
    <>
      <rect x="4" y="15" width="16" height="5" rx="1"/>
      <rect x="6" y="10" width="12" height="5" rx="1"/>
      <rect x="8" y="5" width="8" height="5" rx="1"/>
    </>
  )}
  {phase === 'ship' && (
    <>
      <path d="M4 8 L12 4 L20 8 L20 18 L12 22 L4 18 Z"/>
      <line x1="4" y1="8" x2="12" y2="12"/>
      <line x1="20" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="12" x2="12" y2="22"/>
    </>
  )}
  {phase === 'launch' && (
    <>
      <path d="M14 4 Q20 6 20 12 Q20 14 18 16 L12 16 Q11 14 11 12 Q11 6 14 4 Z"/>
      <circle cx="15.5" cy="11" r="1.5" fill="currentColor" stroke="none"/>
      <path d="M14 16 L12 20"/>
      <path d="M11 17 L9 21"/>
    </>
  )}
  {phase === 'scale' && (
    <>
      <line x1="4" y1="20" x2="4" y2="15"/>
      <line x1="10" y1="20" x2="10" y2="11"/>
      <line x1="16" y1="20" x2="16" y2="7"/>
      <polyline points="3 11 9 7 15 4 21 3"/>
      <circle cx="21" cy="3" r="1.6" fill="#E85D3C" stroke="none"/>
    </>
  )}
</svg>
